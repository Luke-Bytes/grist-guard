BROKER_PORT=8787
BROKER_HOST=127.0.0.1
BROKER_AUTH_TOKENS=local-dev-token
BROKER_DB_PATH=./data/grist-guard.sqlite
GRIST_BASE_URL=http://127.0.0.1:8484
GRIST_API_KEY=replace-me
BROKER_ALLOW_DESTRUCTIVE=false
BROKER_AUTO_APPLY_ROW_LIMIT=50
BROKER_MAX_PLAN_ROWS=100
BROKER_READ_SAMPLE_LIMIT=25
BROKER_REQUIRE_APPROVAL_FOR_SCHEMA=true
BROKER_REQUIRE_APPROVAL_FOR_FORMULAS=true
BROKER_REQUIRE_RECOVERY_MARKER=true
BROKER_HEALTHCHECK_TTL_MS=5000
BROKER_RETRY_ATTEMPTS=3
BROKER_RETRY_BASE_MS=250
BROKER_RETENTION_DAYS=90
BROKER_ALLOWED_DOCUMENTS_JSON={"exampleDoc":{"name":"Example","tables":{"Tasks":{"read":true,"write":true,"allowedColumns":["Title","Status","Notes"]}}}}
